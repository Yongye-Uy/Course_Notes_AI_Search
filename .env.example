# Copy this file to .env and fill in your own values.
# .env is gitignored -- never commit real credentials.

# --- NVIDIA OpenAI-compatible endpoint (required) ---
# Get a key at https://build.nvidia.com/ -- do NOT paste it anywhere
# public (chat logs, screenshots, commits).
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Optional overrides (sane defaults already set in config.py) ---
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# TOP_K_DEFAULT=5
# TEMPERATURE_DEFAULT=1.0
# MAX_TOKENS=4096
# EMBEDDING_MODEL_DEFAULT=all-MiniLM-L6-v2
